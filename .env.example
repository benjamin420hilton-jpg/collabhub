# ===========================================
# CollabHub Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Neon Database
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/collabhub?sslmode=require

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe (Platform Account)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Billing (Pro Subscription)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...

# Platform Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_RATE_FREE=500
PLATFORM_FEE_RATE_PRO=500
DEFAULT_CURRENCY=aud
